    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/legacy-modes": "^6.4.2",
    "@codemirror/state": "^6.5.1",
    "bootstrap": "^5.3.3",
    "codemirror": "^6.0.1",
    "http-z": "github:AlexanderMac/http-z",
